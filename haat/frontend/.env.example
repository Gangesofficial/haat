# Supabase — get from Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API base URL
# Local dev: leave empty (Vite proxy handles /api → localhost:3001)
# Production: set to your Render backend URL (e.g. https://haat-backend.onrender.com)
VITE_API_URL=
